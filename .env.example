# ──────────────────────────────────────────────────────
# LottoLens Workspace — Root Environment Variables
# ──────────────────────────────────────────────────────
# Copy this file to .env at the root of the project:
# cp .env.example .env
#
# Docker Compose will automatically load the values from the root .env file.

# Server-side Google Gemini API Key
GEMINI_API_KEY=

# JSON Web Token config
JWT_SECRET=dev-only-change-me
JWT_EXPIRY_HOURS=24
