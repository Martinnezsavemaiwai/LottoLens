# ──────────────────────────────────────────────────────
# Thai Lotto Analytics — Backend Environment Variables
# ──────────────────────────────────────────────────────
# คัดลอกไฟล์นี้เป็น .env แล้วแก้ไขค่าให้ตรงกับ environment จริง

# PostgreSQL Connection String
# รูปแบบ: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:password@localhost:5432/lotto_db?schema=public"

# ตัวอย่างสำหรับ Supabase
# DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres"

# ตัวอย่างสำหรับ Railway
# DATABASE_URL="postgresql://postgres:[password]@[host].railway.app:5432/railway"

# ตัวอย่างสำหรับ Neon
# DATABASE_URL="postgresql://[user]:[password]@[host]/[database]?sslmode=require"
